#!/bin/bash
# Wrapper to run Build ISO GUI

# Detect installation directory
# FIRST check for local/development directory (relative to script location)
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
LOCAL_DIR="$SCRIPT_DIR/../share/build-iso"

if [[ -e "$LOCAL_DIR/gui/main_gui.py" ]]; then
    # Development mode - use local directory
    BUILD_ISO_DIR="$LOCAL_DIR"
else
    # Installed mode - look in system paths
    for i in /usr/share/build-iso; do
        if [[ -e "$i" ]]; then
            BUILD_ISO_DIR="$i"
            break
        fi
    done
fi

if [[ -z "$BUILD_ISO_DIR" ]]; then
    echo "Error: Build ISO not found." >&2
    exit 1
fi

# Run GUI entry point
exec python3 "$BUILD_ISO_DIR/gui/main_gui.py" "$@"
